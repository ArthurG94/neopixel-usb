{
  "build": {
    "core": "arduino",
    "cpu": "cortex-m0",
    "extra_flags": "-DSTM32F072xB -DARDUINO_ARCH_STM32",
    "f_cpu": "48000000L",
    "mcu": "stm32f072cbt6",
    "series": "STM32F0xx",
    "variant": "STM32F0xx/F072C8(T-U)_F072CB(T-U-Y)"
  },
  "connectivity": [],
  "debug": {
    "jlink_device": "STM32F072CB",
    "svd_path": "STM32F0x2.svd",
    "tools": {
      "blackmagic": {
        "hwids": [["0x1D50", "0x6018"]],
        "require_debug_port": "gdb"
      },
      "jlink": {
        "server": {
          "arguments": [
            "-select", "USB",
            "-device", "STM32F072CB",
            "-endian", "little",
            "-if", "SWD",
            "-speed", "auto",
            "-ir",
            "-singlerun"
          ],
          "executable": "JLinkGDBServerCL",
          "ready_pattern": "Listening on TCP/IP port"
        }
      },
      "stlink": {
        "server": {
          "arguments": [
            "-f", "interface/stlink.cfg",
            "-c", "transport select hla_swd",
            "-f", "target/stm32f0x.cfg",
            "-c", "reset_config none separate"
          ],
          "executable": "bin/openocd",
          "package": "tool-openocd"
        }
      }
    }
  },
  "frameworks": ["arduino", "cmsis", "stm32cube"],
  "name": "Generic STM32F072CB",
  "upload": {
    "maximum_ram_size": 16384,
    "maximum_size": 131072,
    "protocol": "stlink",
    "protocols": ["blackmagic", "dfu", "jlink", "stlink"]
  },
  "url": "https://www.st.com/en/microcontrollers-microprocessors/stm32f072cb.html",
  "vendor": "Generic"
}
